# --- OpenAI (used from Week 2 onwards) -------------------------------------
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini

# --- Bot identity (shown in Talk's bot list) -------------------------------
BOT_DISPLAY_NAME=GCF AI Bot
BOT_DESCRIPTION=AI-powered assistant using OpenAI ChatGPT.

# --- AppAPI ----------------------------------------------------------------
# AppAPI injects these at deploy time. Only set them for local development
# (e.g. when running `python -m app.main` outside of a managed deployment).
#
# APP_ID=gcf_talk_ai_bot
# APP_VERSION=0.1.0
# APP_SECRET=change-me-shared-with-nextcloud
# APP_HOST=0.0.0.0
# APP_PORT=8080
# NEXTCLOUD_URL=http://nextcloud.local
